# App
APP_NAME=AuraGram
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:5173

# Database — local MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=auragram

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis (Celery task queue)
REDIS_URL=redis://localhost:6379/0

# File Storage — Cloudinary
# (leave blank to use local MinIO instead)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI — local inference (no API key needed)
AI_DEVICE=cuda
LLAVA_MODEL_PATH=./ai_models/weights/llava-v1.5-7b.Q4_K_M.gguf
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
YOLO_MODEL_PATH=./ai_models/weights/yolov8n.pt
